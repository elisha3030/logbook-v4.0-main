# =============================================================================
#  Logbook System — Environment Variables Template
#  Copy this file to ".env" and fill in your actual values.
#  NEVER commit your real ".env" file to version control.
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# A long, random string used to sign session cookies.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace_with_a_long_random_string

# ── Firebase Admin (Server-side) ──────────────────────────────────────────────
# Path to your Firebase Service Account JSON key (relative to project root).
# Download from: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT_PATH=./config/firebase-key.json

# ── Firebase Web SDK (Client-side / Frontend) ─────────────────────────────────
# Found in: Firebase Console → Project Settings → Your apps → Web app → Config
FIREBASE_API_KEY=your_api_key_here
FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
FIREBASE_APP_ID=your_app_id
FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
